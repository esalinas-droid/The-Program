{
  "expo": {
    "name": "The Program",
    "slug": "the-program-app",
    "owner": "the_program",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-icon.png",
    "scheme": "theprogram",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.theprogramapp.ai",
      "icon": "./assets/logo-icon.png",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Get training reminders and PR alerts",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "buildNumber": "20"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-icon.png",
        "backgroundColor": "#0A0A0C"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.theprogramapp.ai",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo-full.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0C"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#C55A11",
          "sounds": []
        }
      ],
      "expo-apple-authentication",
      "expo-document-picker",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow The Program to take photos of your workout program and medical documents.",
          "photosPermission": "Allow The Program to access your photos for uploading workout programs and medical documents."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "22450607-155d-450e-a3ad-5dfa37664b96"
      }
    }
  }
}
