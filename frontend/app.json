{
  "expo": {
    "name": "The Program",
    "slug": "the-program-app",
    "owner": "the_program",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-icon.png",
    "scheme": "theprogram",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.theprogram.app",
      "icon": "./assets/logo-icon.png",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Get training reminders and PR alerts",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-icon.png",
        "backgroundColor": "#0A0A0C"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.theprogram.app",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo-full.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0C"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#C55A11",
          "sounds": []
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}